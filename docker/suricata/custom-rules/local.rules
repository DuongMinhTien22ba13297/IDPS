# =====================================================================
#  IDPS Custom Rules — Layer 7 Web Attack Detection
#  Action is set to 'drop' to block immediately.
# =====================================================================

# --- SQL Injection Detection ---
drop http any any -> $HOME_NET any (msg:"IDPS SQL Injection Attempt - UNION SELECT"; \
  flow:established,to_server; \
  content:"UNION"; nocase; content:"SELECT"; nocase; distance:0; within:20; \
  classtype:web-application-attack; sid:1000001; rev:1; \
  metadata:attack_type sql_injection;)

drop http any any -> $HOME_NET any (msg:"IDPS SQL Injection Attempt - OR 1=1"; \
  flow:established,to_server; \
  content:"OR"; nocase; content:"1=1"; distance:0; within:10; \
  classtype:web-application-attack; sid:1000002; rev:1;)

drop http any any -> $HOME_NET any (msg:"IDPS SQL Injection - Comment Marker"; \
  flow:established,to_server; \
  content:"--"; content:"'"; \
  classtype:web-application-attack; sid:1000003; rev:1;)

# --- XSS Detection ---
drop http any any -> $HOME_NET any (msg:"IDPS XSS Attempt - Script Tag"; \
  flow:established,to_server; \
  content:"<script"; nocase; \
  classtype:web-application-attack; sid:1000010; rev:1;)

drop http any any -> $HOME_NET any (msg:"IDPS XSS Attempt - Event Handler"; \
  flow:established,to_server; \
  pcre:"/on(load|error|click|mouseover)\s*=/i"; \
  classtype:web-application-attack; sid:1000011; rev:1;)

drop http any any -> $HOME_NET any (msg:"IDPS XSS Attempt - javascript URI"; \
  flow:established,to_server; \
  content:"javascript:"; nocase; \
  classtype:web-application-attack; sid:1000012; rev:1;)

# --- Command Injection ---
drop http any any -> $HOME_NET any (msg:"IDPS Command Injection - Semicolon"; \
  flow:established,to_server; \
  content:";"; content:"/bin/"; distance:0; within:20; \
  classtype:web-application-attack; sid:1000020; rev:1;)

drop http any any -> $HOME_NET any (msg:"IDPS Command Injection - Pipe"; \
  flow:established,to_server; \
  content:"|"; content:"/etc/passwd"; distance:0; within:30; \
  classtype:web-application-attack; sid:1000021; rev:1;)

# --- Path Traversal ---
drop http any any -> $HOME_NET any (msg:"IDPS Path Traversal Attempt"; \
  flow:established,to_server; \
  content:"../"; content:"../"; distance:0; within:10; \
  classtype:web-application-attack; sid:1000030; rev:1;)

# --- Malware Download Detection ---
drop http any any -> any any (msg:"IDPS Potential PE Download"; \
  flow:established,to_client; \
  content:"MZ"; offset:0; depth:2; \
  classtype:trojan-activity; sid:1000040; rev:1;)

# --- DNS Tunneling ---
drop dns any any -> any any (msg:"IDPS DNS Tunneling - Long Query"; \
  dns.query; content:"."; content:"."; distance:1; within:10; \
  dsize:>100; \
  classtype:policy-violation; sid:1000050; rev:1;)
